generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum SubscriptionTier {
    FREE
    PLAYER_PRO
    PLAYER_ALL_PRO
    PLAYER_ELITE
    COMMISSIONER_PRO
    COMMISSIONER_ALL_PRO
    COMMISSIONER_ELITE
}

model User {
    id               String           @id @default(cuid())
    email            String           @unique
    name             String?
    hashedPassword   String?
    emailVerified    DateTime?
    image            String?
    // Tracks the active Player plan tier for fast JWT/navbar reads.
    // Commissioner plans are tracked only in the subscriptions table.
    subscriptionTier SubscriptionTier @default(FREE)
    stripeCustomerId String?          @unique
    sleeperUserId    String?          @unique
    createdAt        DateTime         @default(now())
    updatedAt        DateTime         @updatedAt

    accounts         Account[]
    sessions         Session[]
    subscriptions    Subscription[]
    connectedLeagues ConnectedLeague[]
    leagues          League[]
    commissionerDues LeagueDues[]      @relation("CommissionerDues")
    duesMemberships  DuesMember[]      @relation("MemberDues")
    proBowlEntries   ProBowlEntry[]    @relation("ProBowlEntries")
    announcements    Announcement[]    @relation("AuthorAnnouncements")
    leagueInvites    LeagueInvite[]    @relation("LeagueInvites")
}

model League {
    id              String    @id @default(cuid())
    userId          String
    platform        String    // "sleeper"
    leagueId        String    // external platform ID
    leagueName      String
    season          String
    status          String    // pre_draft | drafting | in_season | complete
    totalRosters    Int
    scoringType     String?   // ppr | half_ppr | std
    leagueType      String    @default("Redraft")  // "Dynasty" | "Redraft"
    scoringSettings Json?     // Sleeper scoring_settings (pass_td, bonus_rec_te, etc.)
    avatar          String?
    rosterPositions String[]
    sleeperUserId   String?   // Sleeper user_id of whoever synced this record (fallback for commissioner check)
    standings       Json?     // refreshed hourly: [{ rosterId, ownerId, wins, losses, ties, fpts }]
    currentMatchup  Json?     // refreshed every 3 min on game days
    assignedPlanId  String?   // FK to Subscription.id — which plan this league is assigned to
    assignedPlanType String?  // "player" | "commissioner"
    lastSyncedAt    DateTime?
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
    calendarEvents   LeagueCalendarEvent[]
    proBowlContests  ProBowlContest[]

    @@unique([userId, platform, leagueId])
    @@index([userId])
}

// ── League Calendar ───────────────────────────────────────────────────────────

model LeagueCalendarEvent {
    id          String   @id @default(cuid())
    leagueDbId  String   // FK to League.id (the synced league record)
    title       String
    date        DateTime // start date/time of the event
    endDate     DateTime?
    // draft | trade_deadline | waiver_deadline | regular_season_end | playoff_start | championship | custom
    type        String   @default("custom")
    description String?  @db.Text
    allDay      Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    league      League   @relation(fields: [leagueDbId], references: [id], onDelete: Cascade)

    @@index([leagueDbId])
    @@index([date])
}

// Auth.js (NextAuth v5) required models
model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Auth.js email provider verification tokens
model VerificationToken {
    identifier String
    token      String
    expires    DateTime

    @@unique([identifier, token])
}

model Subscription {
    id                   String           @id @default(cuid())
    userId               String           // No longer @unique — users can have multiple subs
    stripeSubscriptionId String?          @unique
    stripeCustomerId     String?
    // "player" | "commissioner"
    // @default("player") ensures existing rows migrated from the one-sub model get the right value
    type                 String           @default("player")
    leagueName           String?          // human-readable league name, set at commissioner checkout
    leagueSize           Int?             // null for player plans; 8/10/12/14/16/32 for commissioner
    tier                 SubscriptionTier @default(FREE)
    status               String           @default("inactive")
    currentPeriodStart   DateTime?
    currentPeriodEnd     DateTime?
    cancelAtPeriodEnd    Boolean          @default(false)
    createdAt            DateTime         @default(now())
    updatedAt            DateTime         @updatedAt

    user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    leagueDues LeagueDues?
}

model ConnectedLeague {
    id          String   @id @default(cuid())
    userId      String
    leagueName  String
    platform    String?  // "ESPN", "Yahoo", "Sleeper", "NFL", "CBS", "Other"
    leagueExtId String?  // external league ID from platform
    createdAt   DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

// ── League Dues & Payout Tracker ─────────────────────────────────────────────

// One tracker per commissioner subscription. Holds the buy-in, pot, and status.
model LeagueDues {
    id                   String    @id @default(cuid())
    subscriptionId       String?   @unique  // linked to commissioner sub (null for extra-season trackers)
    commissionerId       String              // userId of the commissioner
    leagueName           String
    season               String             // e.g. "2025"
    buyInAmount          Float              // per-player buy-in in dollars
    teamCount            Int                // number of teams in the league
    collectedAmount      Float              @default(0) // cash actually received (manually entered by commissioner)
    potTotal             Float              @default(0) // running total of confirmed payments (paidCount × buyIn)
    // setup | active | season_ended | pending_approval | approved | paid_out
    status               String             @default("setup")
    platform             String?            // "Sleeper" | "ESPN" | "Yahoo" | "Manual"
    externalLeagueId     String?            // for future API integration
    createdAt            DateTime           @default(now())
    updatedAt            DateTime           @updatedAt

    commissioner         User               @relation("CommissionerDues", fields: [commissionerId], references: [id], onDelete: Cascade)
    subscription         Subscription?      @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
    members              DuesMember[]
    payoutSpots          PayoutSpot[]
    proposals            PayoutProposal[]
    documents            LeagueDocument[]
    futureDues           FutureDuesObligation[]
    announcements        Announcement[]

    @@index([commissionerId])
}

// One row per league member (roster player).
model DuesMember {
    id              String    @id @default(cuid())
    leagueDuesId    String
    userId          String?   // null until member creates a FantasyIQ account and links
    displayName     String    // name entered by commissioner or pulled from platform
    email           String?   // for payment link delivery
    teamName        String?
    // unpaid | paid | pending_refund
    duesStatus      String    @default("unpaid")
    paidAt          DateTime?
    paymentMethod   String?   // "stripe_direct" | "stripe_on_behalf" | null
    stripePaymentId String?   // Stripe payment intent or checkout session ID
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    leagueDues      LeagueDues  @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)
    user            User?       @relation("MemberDues", fields: [userId], references: [id], onDelete: SetNull)
    payoutItems     PayoutProposalItem[]
    pollVotes       PollVote[]
    futureDues      FutureDuesObligation[]

    @@index([leagueDuesId])
    @@index([userId])
}

// Configurable payout spots set by the commissioner before season end.
// Amounts across all spots must sum to the full pot.
model PayoutSpot {
    id           String  @id @default(cuid())
    leagueDuesId String
    label        String  // "1st Place", "2nd Place", "Weekly High Score Wk 1", etc.
    amount       Float   // dollar amount for this spot
    sortOrder    Int     @default(0)

    leagueDues   LeagueDues           @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)
    proposalItem PayoutProposalItem[]

    @@index([leagueDuesId])
}

// Auto-generated at season end. Commissioner reviews and approves/rejects.
model PayoutProposal {
    id           String   @id @default(cuid())
    leagueDuesId String
    // pending_commissioner | approved | rejected | polling | poll_passed | poll_failed
    status       String   @default("pending_commissioner")
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    leagueDues   LeagueDues           @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)
    items        PayoutProposalItem[]
    poll         LeaguePoll?

    @@index([leagueDuesId])
}

// Each line in the proposal: which member wins which spot.
model PayoutProposalItem {
    id           String  @id @default(cuid())
    proposalId   String
    memberId     String
    payoutSpotId String
    amount       Float
    // pending | payment_link_sent | claimed | paid_out
    status       String  @default("pending")
    stripePaymentLinkId String?
    claimedAt    DateTime?

    proposal     PayoutProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
    member       DuesMember     @relation(fields: [memberId], references: [id], onDelete: Cascade)
    payoutSpot   PayoutSpot     @relation(fields: [payoutSpotId], references: [id], onDelete: Cascade)

    @@index([proposalId])
}

// Created when commissioner rejects a proposal. 75%+ yes = proposal stands.
model LeaguePoll {
    id          String    @id @default(cuid())
    proposalId  String    @unique
    question    String    @default("Do you approve the proposed payout?")
    expiresAt   DateTime  // commissioner sets deadline
    // open | passed | failed
    status      String    @default("open")
    createdAt   DateTime  @default(now())

    proposal    PayoutProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
    votes       PollVote[]
}

// One vote per member per poll.
model PollVote {
    id         String    @id @default(cuid())
    pollId     String
    memberId   String
    vote       Boolean   // true = yes (approve), false = no (reject)
    votedAt    DateTime  @default(now())

    poll       LeaguePoll  @relation(fields: [pollId], references: [id], onDelete: Cascade)
    member     DuesMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

    @@unique([pollId, memberId])  // one vote per member per poll
}

// ── Pro Bowl Contest ─────────────────────────────────────────────────────────

model ProBowlContest {
    id                String   @id @default(cuid())
    leagueId          String
    name              String
    openAt            DateTime
    lockAt            DateTime
    endAt             DateTime
    isActive          Boolean  @default(true)
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt

    rosterConfigJson  Json
    scoringConfigJson Json

    league  League         @relation(fields: [leagueId], references: [id])
    entries ProBowlEntry[]
}

// ── League Documents (bylaws, rulebooks, etc.) ────────────────────────────────

model LeagueDocument {
    id           String   @id @default(cuid())
    leagueDuesId String
    label        String   // e.g. "Rulebook 2025", "League Bylaws"
    url          String   // Google Drive / Dropbox share link
    createdAt    DateTime @default(now())

    leagueDues   LeagueDues @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)

    @@index([leagueDuesId])
}

// ── League Announcements ─────────────────────────────────────────────────────

model Announcement {
    id           String   @id @default(cuid())
    leagueDuesId String
    authorId     String
    body         String   @db.Text
    mediaUrl     String?  // direct image / GIF URL (normalised from Giphy share links etc.)
    pinned       Boolean  @default(false)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    leagueDues   LeagueDues @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)
    author       User       @relation("AuthorAnnouncements", fields: [authorId], references: [id], onDelete: Cascade)

    @@index([leagueDuesId])
}

// Tracks which members owe dues in future seasons (e.g. acquired a future draft pick).
model FutureDuesObligation {
    id            String    @id @default(cuid())
    leagueDuesId  String
    memberId      String
    season        String    // "2026" | "2027" | "2028"
    amount        Float
    notes         String?   // e.g. "Acquired 2027 1st round pick from Team X"
    // pending | paid
    status        String    @default("pending")
    paidAt        DateTime?
    paymentMethod String?   // "stripe_on_behalf" | "manual" | null
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    leagueDues    LeagueDues  @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)
    member        DuesMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

    @@unique([leagueDuesId, memberId, season])
    @@index([leagueDuesId])
    @@index([memberId])
}

// ── League Invite Links ───────────────────────────────────────────────────────

model LeagueInvite {
    id              String   @id @default(cuid())
    token           String   @unique @default(cuid())
    sleeperLeagueId String
    leagueName      String
    season          String
    createdById     String
    createdAt       DateTime @default(now())

    createdBy       User     @relation("LeagueInvites", fields: [createdById], references: [id], onDelete: Cascade)

    @@index([sleeperLeagueId])
}

// ── Sleeper Player Database ──────────────────────────────────────────────────

// Downloaded once per day via /api/cron/sleeper-players.
// Sleeper player IDs are used throughout league/roster/matchup data.
// Enriched daily via /api/cron/espn-rosters with injury and physical data.
model SleeperPlayer {
    playerId        String   @id   // Sleeper's player_id string
    fullName        String
    position        String
    team            String
    active          Boolean  @default(true)
    // ESPN enrichment fields (updated daily by espn-rosters cron)
    espnId          String?
    injuryStatus    String?  // Active | Questionable | Doubtful | Out | IR | PUP
    injuryBodyPart  String?
    jerseyNumber    Int?
    height          String?  // e.g. "6' 2\""
    weight          Int?     // lbs
    birthDate       String?  // birth_date from Sleeper API e.g. "1998-05-15" — canonical DOB source
    age             Int?     // pre-calculated by Sleeper (kept as fallback when birthDate is absent)
    updatedAt       DateTime @updatedAt

    projections     PlayerProjection[]
}

// Weekly fantasy point projections — populated by /api/cron/sleeper-projections.
model PlayerProjection {
    id        String   @id @default(cuid())
    playerId  String
    season    String
    week      Int
    pointsPpr Float
    pointsStd Float
    pointsHalfPpr Float
    updatedAt DateTime @updatedAt @default(now())

    player    SleeperPlayer @relation(fields: [playerId], references: [playerId], onDelete: Cascade)

    @@unique([playerId, season, week])
    @@index([season, week])
}

model ProBowlEntry {
    id          String   @id @default(cuid())
    contestId   String
    userId      String
    totalPoints Float    @default(0)
    isFinal     Boolean  @default(false)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    contest ProBowlContest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
    user    User              @relation("ProBowlEntries", fields: [userId], references: [id], onDelete: Cascade)
    slots   ProBowlEntrySlot[]

    @@unique([contestId, userId])
    @@index([contestId])
}

model ProBowlEntrySlot {
    id        String    @id @default(cuid())
    entryId   String
    position  String    // "QB" | "RB" | "WR" | "TE" | "FLEX" | "SUPER_FLEX" | "K" | "DEF"
    playerId  String    // SleeperPlayer.playerId
    salary    Int
    lockedAt  DateTime?
    points    Float     @default(0)

    entry  ProBowlEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

    @@index([entryId])
}

model FantasyCalcValue {
    id           String   @id @default(cuid())
    fcId         Int      @unique
    playerName   String
    nameLower    String   @unique
    position     String
    team         String?
    age          Float?
    dynastyValue   Int      // KTC 1QB dynasty (0–9999)
    dynastyValueSf Int      @default(0)  // KTC superflex dynasty
    redraftValue   Int      // KTC 1QB redraft (0–9999)
    redraftValueSf Int      @default(0)  // KTC superflex redraft
    trend30Day     Int?
    updatedAt    DateTime @updatedAt @default(now())

    @@index([nameLower])
}

// Weekly snapshot of power rankings per league, written by the power-rankings cron.
// Powers the historical trend view on the Rankings page.
model PowerRankingSnapshot {
    id        String   @id @default(cuid())
    leagueId  String
    week      Int
    data      Json     // array of teams with powerScore, record, PF, PA, dtv
    createdAt DateTime @default(now())

    @@unique([leagueId, week])
}

// Daily snapshot of KTC values + Sleeper metadata, taken before each fantasycalc-sync run.
// Powers the /api/players/delta endpoint (what changed since yesterday).
// Retention: 7 days (older rows deleted by the cron).
model FantasyCalcSnapshot {
    id             String   @id @default(cuid())
    nameLower      String
    position       String
    dynastyValue   Int
    dynastyValueSf Int
    redraftValue   Int
    redraftValueSf Int
    team           String?       // Sleeper team at snapshot time
    injuryStatus   String?       // Sleeper injury status at snapshot time
    takenAt        DateTime @default(now())

    @@index([nameLower])
    @@index([takenAt])
}
