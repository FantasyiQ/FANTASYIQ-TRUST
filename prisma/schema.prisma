generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum SubscriptionTier {
    FREE
    PLAYER_PRO
    PLAYER_ALL_PRO
    PLAYER_ELITE
    COMMISSIONER_PRO
    COMMISSIONER_ALL_PRO
    COMMISSIONER_ELITE
}

model User {
    id               String           @id @default(cuid())
    email            String           @unique
    name             String?
    hashedPassword   String?
    emailVerified    DateTime?
    image            String?
    // Tracks the active Player plan tier for fast JWT/navbar reads.
    // Commissioner plans are tracked only in the subscriptions table.
    subscriptionTier SubscriptionTier @default(FREE)
    stripeCustomerId String?          @unique
    createdAt        DateTime         @default(now())
    updatedAt        DateTime         @updatedAt

    accounts         Account[]
    sessions         Session[]
    leagues          League[]
    subscriptions    Subscription[]
    connectedLeagues ConnectedLeague[]
}

// Auth.js (NextAuth v5) required models
model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Auth.js email provider verification tokens
model VerificationToken {
    identifier String
    token      String
    expires    DateTime

    @@unique([identifier, token])
}

model Subscription {
    id                   String           @id @default(cuid())
    userId               String           // No longer @unique — users can have multiple subs
    stripeSubscriptionId String?          @unique
    stripeCustomerId     String?
    // "player" | "commissioner"
    // @default("player") ensures existing rows migrated from the one-sub model get the right value
    type                 String           @default("player")
    leagueName           String?          // human-readable league name, set at commissioner checkout
    leagueSize           Int?             // null for player plans; 8/10/12/14/16/32 for commissioner
    discountPct          Int?             // 0, 15, or 25 — stored for display/receipts
    tier                 SubscriptionTier @default(FREE)
    status               String           @default("inactive")
    currentPeriodStart   DateTime?
    currentPeriodEnd     DateTime?
    cancelAtPeriodEnd    Boolean          @default(false)
    createdAt            DateTime         @default(now())
    updatedAt            DateTime         @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConnectedLeague {
    id          String   @id @default(cuid())
    userId      String
    leagueName  String
    platform    String?  // "ESPN", "Yahoo", "Sleeper", "NFL", "CBS", "Other"
    leagueExtId String?  // external league ID from platform
    createdAt   DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model League {
    id              String    @id @default(cuid())
    userId          String
    platform        String    @default("sleeper")
    leagueId        String    // External platform league ID
    leagueName      String
    season          String
    status          String    // pre_draft | drafting | in_season | complete
    totalRosters    Int
    scoringType     String?
    avatar          String?
    rosterPositions Json?
    lastSyncedAt    DateTime?
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, platform, leagueId])
}
