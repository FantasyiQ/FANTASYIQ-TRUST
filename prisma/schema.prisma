generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum SubscriptionTier {
    FREE
    PLAYER_PRO
    PLAYER_ALL_PRO
    PLAYER_ELITE
    COMMISSIONER_PRO
    COMMISSIONER_ALL_PRO
    COMMISSIONER_ELITE
}

model User {
    id               String           @id @default(cuid())
    email            String           @unique
    name             String?
    hashedPassword   String?
    emailVerified    DateTime?
    image            String?
    // Tracks the active Player plan tier for fast JWT/navbar reads.
    // Commissioner plans are tracked only in the subscriptions table.
    subscriptionTier SubscriptionTier @default(FREE)
    stripeCustomerId String?          @unique
    sleeperUserId    String?          @unique
    espnS2           String?          // ESPN espn_s2 session cookie
    swid             String?          // ESPN SWID cookie
    yahooUserId      String?          @unique  // Yahoo GUID
    yahooAccessToken  String?
    yahooRefreshToken String?
    yahooTokenExpiresAt DateTime?
    nflSid           String?          // NFL.com session cookie (sid)
    isAdmin              Boolean          @default(false)
    onboardingComplete   Boolean          @default(false)
    acceptedTerms        Boolean          @default(false)
    acceptedTermsAt      DateTime?
    acceptedTermsVersion String?
    createdAt            DateTime         @default(now())
    updatedAt            DateTime         @updatedAt

    accounts         Account[]
    sessions         Session[]
    subscriptions    Subscription[]
    connectedLeagues ConnectedLeague[]
    leagues          League[]
    commissionerDues LeagueDues[]      @relation("CommissionerDues")
    duesMemberships  DuesMember[]      @relation("MemberDues")
    paymentAuditLogs PaymentAuditLog[] @relation("AuditLogActor")
    announcements    Announcement[]    @relation("AuthorAnnouncements")
    leagueInvites    LeagueInvite[]    @relation("LeagueInvites")
    notifications         Notification[]
    notificationPrefs     NotificationPreference[]
    // Weekly DFS Challenge
    dfsLineups            DFSLineup[]

    // IDS analytics
    featureEvents         FeatureUsageEvent[]
    syncRecoveryEvents    SyncRecoveryEvent[]
    churnRiskEvents       ChurnRiskEvent[]
    prediction            UserPrediction?

    // Player Reliability Score
    prsScore              Int               @default(0)  // cached final PRS (0-100) for fast reads
    prsEvents             PrsEvent[]
    prsRecord             PrsScore?
    prsHistorySubmissions PrsHistoryImport[] @relation("PrsHistorySubmitter")

    // Dynasty Skill Score
    dssScore              Int               @default(0)  // cached final DSS (0-100) for fast reads
    dssRecord             DssScore?

    // LeagueFinder
    trustScore            Int               @default(0)
    lfReviews             LFReview[]        @relation("ReviewerReviews")
    lfVotes               LFReviewVote[]    @relation("ReviewVotes")
    ownedCommissioner     LFCommissioner?   @relation("CommissionerOwner")
    lfReplies             LFReviewReply[]   @relation("ReviewReplies")
    lfJoinRequests        LFJoinRequest[]   @relation("LeagueJoinRequests")

    // Auth tokens
    passwordResetTokens      PasswordResetToken[]
    emailVerificationTokens  EmailVerificationToken[]

    syncExclusions    SyncExclusion[]
}

// ── Sync Exclusions ──────────────────────────────────────────────────────────
// Records leagues the user has explicitly unsynced so they are never
// automatically recreated by a future re-sync from the sync page.

model SyncExclusion {
    id        String   @id @default(cuid())
    userId    String
    platform  String   // "sleeper" | "espn" | "yahoo"
    leagueId  String   // external platform league ID
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, platform, leagueId])
    @@index([userId])
}

// ── Internal Data System (IDS) ───────────────────────────────────────────────

model FeatureUsageEvent {
    id        String   @id @default(cuid())
    userId    String
    feature   String   // e.g. "trade_evaluator" | "draft_report" | "roster_values" | "league_refresh"
    metadata  Json?    // arbitrary context (platform, leagueId, etc.)
    createdAt DateTime @default(now())

    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([feature])
    @@index([createdAt])
}

model SyncRecoveryEvent {
    id          String    @id @default(cuid())
    userId      String
    leagueDbId  String?   // League.id — null if failure before league identified
    platform    String    // "sleeper" | "espn" | "yahoo"
    // "auth" | "rate_limit" | "network" | "data" | "unknown"
    errorType   String    @default("unknown")
    errorMsg    String?
    attempt     Int       @default(1)
    resolved    Boolean   @default(false)
    resolvedAt  DateTime?
    createdAt   DateTime  @default(now())

    user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([platform, resolved])
    @@index([leagueDbId])
    @@index([createdAt])
}

model ChurnRiskEvent {
    id          String    @id @default(cuid())
    userId      String
    riskScore   Int       // 0-100
    riskTier    String    // "low" | "medium" | "high"
    signals     Json      // string[] of which signals fired
    nudgeSent   Boolean   @default(false)
    nudgeSentAt DateTime?
    resolved    Boolean   @default(false)
    resolvedAt  DateTime?
    createdAt   DateTime  @default(now())

    user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([riskTier, resolved])
    @@index([createdAt])
}

// ── Predictive Models (Engine 7) ─────────────────────────────────────────────
// One row per user, upserted daily by the predictive-models cron.

model UserPrediction {
    id                    String   @id @default(cuid())
    userId                String   @unique
    // All probabilities: 0.0–1.0 (store as float, display as %)
    churnProbability      Float    @default(0)
    conversionProbability Float    @default(0)  // FREE/Player → commissioner
    upgradeProbability    Float    @default(0)  // current tier → next tier
    modelVersion          String   @default("v1")
    computedAt            DateTime @default(now())

    user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([churnProbability])
    @@index([conversionProbability])
    @@index([computedAt])
}

model League {
    id              String    @id @default(cuid())
    userId          String
    platform        String    // "sleeper" | "espn" | "yahoo"
    leagueId        String    // external platform ID
    leagueName      String
    season          String
    status          String    // pre_draft | drafting | in_season | complete
    totalRosters    Int
    scoringType     String?   // ppr | half_ppr | std
    leagueType      String    @default("Redraft")  // "Dynasty" | "Redraft"
    scoringSettings Json?     // Sleeper scoring_settings (pass_td, bonus_rec_te, etc.)
    avatar          String?
    rosterPositions String[]
    sleeperUserId   String?   // Sleeper user_id of whoever synced this record (fallback for commissioner check)
    standings       Json?     // refreshed hourly: [{ rosterId, ownerId, wins, losses, ties, fpts }]
    currentMatchup  Json?     // refreshed every 3 min on game days
    assignedPlanId  String?   // FK to Subscription.id — which plan this league is assigned to
    assignedPlanType String?  // "player" | "commissioner"
    draftStartTime   BigInt?   // epoch ms of scheduled draft start (from Sleeper); null = not scheduled
    draftStatus      String?   // pre_draft | drafting | complete (Sleeper draft status)
    draftType        String?   // "auction" | "snake" | "linear" (Sleeper draft type)
    playoffWeekStart Int?      // week number when playoffs begin (from Sleeper or manual)
    champWeek        Int?      // week number of championship game (derived or manual)
    lastSyncedAt     DateTime?
    // Sync health (Engine 1 — Sync Failure Auto-Recovery)
    syncStatus       String    @default("ok")   // "ok" | "failing" | "failed"
    syncErrorCount   Int       @default(0)
    syncLastError    String?
    syncLastErrorAt  DateTime?
    // League health (Engine 5 — League Health Engine)
    healthScore      Int       @default(0)      // 0-100 composite
    healthTier       String    @default("unknown") // "healthy" | "fair" | "unhealthy" | "unknown"
    healthSignals    Json?     // { syncScore, dataScore, draftScore, commScore }
    healthCheckedAt  DateTime?
    // Predictive models (Engine 7)
    survivalProbability Float  @default(0.5)    // 0.0-1.0: probability league active next season
    // Historical season rows written by dss-history cron — protected from sync-route deletion
    // so DSS can aggregate standings across multiple completed seasons per dynasty franchise.
    isHistorical    Boolean   @default(false)
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
    dfsContests      DFSContest[]         @relation("DFSSourceLeague")
    calendarEvents   LeagueCalendarEvent[]
    leaguePayouts    LeaguePayout[]
    leaguePayoutWinners LeaguePayoutWinner[]
    announcements    Announcement[]

    @@unique([userId, platform, leagueId])
    @@index([userId])
}

// ── League Calendar ───────────────────────────────────────────────────────────

model LeagueCalendarEvent {
    id          String   @id @default(cuid())
    leagueDbId  String   // FK to League.id (the synced league record)
    title       String
    date        DateTime // start date/time of the event
    endDate     DateTime?
    // draft | trade_deadline | waiver_deadline | regular_season_end | playoff_start | championship | custom
    type        String   @default("custom")
    description String?  @db.Text
    allDay      Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    league      League   @relation(fields: [leagueDbId], references: [id], onDelete: Cascade)

    @@index([leagueDbId])
    @@index([date])
}

// Auth.js (NextAuth v5) required models
model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Auth.js email provider verification tokens
model VerificationToken {
    identifier String
    token      String
    expires    DateTime

    @@unique([identifier, token])
}

model Subscription {
    id                   String           @id @default(cuid())
    userId               String           // No longer @unique — users can have multiple subs
    stripeSubscriptionId String?          @unique
    stripeCustomerId     String?
    // "player" | "commissioner"
    // @default("player") ensures existing rows migrated from the one-sub model get the right value
    type                 String           @default("player")
    leagueName           String?          // human-readable league name, set at commissioner checkout
    leagueSize           Int?             // null for player plans; 8/10/12/14/16/32 for commissioner
    tier                 SubscriptionTier @default(FREE)
    status               String           @default("inactive")
    currentPeriodStart   DateTime?
    currentPeriodEnd     DateTime?
    cancelAtPeriodEnd    Boolean          @default(false)
    createdAt            DateTime         @default(now())
    updatedAt            DateTime         @updatedAt

    user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    leagueDues LeagueDues?
}

model ConnectedLeague {
    id          String   @id @default(cuid())
    userId      String
    leagueName  String
    platform    String?  // "ESPN", "Yahoo", "Sleeper", "NFL", "CBS", "Other"
    leagueExtId String?  // external league ID from platform
    createdAt   DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    // leagueExtId is nullable — the unique constraint prevents duplicate rows when
    // an external ID is present (NULL values are exempt, so manual/name-only rows
    // aren't blocked).
    @@unique([userId, leagueExtId])
}

// ── League Dues & Payout Tracker ─────────────────────────────────────────────

// One tracker per commissioner subscription. Holds the buy-in, pot, and status.
model LeagueDues {
    id                   String    @id @default(cuid())
    subscriptionId       String?   @unique  // linked to commissioner sub (null for extra-season trackers)
    commissionerId       String              // userId of the commissioner
    leagueName           String
    season               String             // e.g. "2025"
    buyInAmount          Float              // per-player buy-in in dollars
    teamCount            Int                // number of teams in the league
    collectedAmount      Float              @default(0) // cash actually received (manually entered by commissioner)
    potTotal             Float              @default(0) // running total of confirmed payments (paidCount × buyIn)
    deadline             DateTime?          // payment deadline for dues reminders
    // setup | active | season_ended | pending_approval | approved | paid_out
    status               String             @default("setup")
    platform             String?            // "Sleeper" | "ESPN" | "Yahoo" | "Manual"
    externalLeagueId     String?            // for future API integration
    createdAt            DateTime           @default(now())
    updatedAt            DateTime           @updatedAt

    commissioner         User               @relation("CommissionerDues", fields: [commissionerId], references: [id], onDelete: Cascade)
    subscription         Subscription?      @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
    members              DuesMember[]
    payoutSpots          PayoutSpot[]
    proposals            PayoutProposal[]
    documents            LeagueDocument[]
    futureDues           FutureDuesObligation[]
    announcements        Announcement[]
    winners              LeagueWinner[]
    auditLogs            PaymentAuditLog[]

    @@index([commissionerId])
}

model LeagueWinner {
    id           String    @id @default(cuid())
    leagueDuesId String
    rank         Int       // 1=1st, 2=2nd, 3=3rd, etc.
    teamName     String
    displayName  String?   // roster owner display name
    amount       Float     // payout amount for this rank
    paidOut      Boolean   @default(false)
    paidAt       DateTime?
    paidByUserId String?
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt

    leagueDues   LeagueDues @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)

    @@unique([leagueDuesId, rank])
    @@index([leagueDuesId])
}

// One row per league member (roster player).
model DuesMember {
    id              String    @id @default(cuid())
    leagueDuesId    String
    userId          String?   // null until member creates a FantasyIQ account and links
    displayName     String    // name entered by commissioner or pulled from platform
    email           String?   // for payment link delivery
    teamName        String?
    // unpaid | paid | pending_refund
    duesStatus      String    @default("unpaid")
    paidAt          DateTime?
    paymentMethod   String?   // "stripe_direct" | "stripe_on_behalf" | null
    stripePaymentId       String?   // Stripe payment intent (direct) or checkout session ID (on_behalf)
    stripePaymentIntentId String?   // Always the pi_xxx — used for dispute/refund webhook lookup
    stripeReceiptUrl      String?   // Stripe hosted receipt URL — surfaced to paid member
    stripeConnectAccountId String?  // Set when winner completes payout onboarding
    createdAt        DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    leagueDues      LeagueDues  @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)
    user            User?       @relation("MemberDues", fields: [userId], references: [id], onDelete: SetNull)
    payoutItems     PayoutProposalItem[]
    pollVotes       PollVote[]
    futureDues      FutureDuesObligation[]

    @@unique([leagueDuesId, userId])
    @@index([leagueDuesId])
    @@index([userId])
}

// Configurable payout spots set by the commissioner before season end.
// Amounts across all spots must sum to the full pot.
model PayoutSpot {
    id           String  @id @default(cuid())
    leagueDuesId String
    label        String  // "1st Place", "2nd Place", "Weekly High Score Wk 1", etc.
    amount       Float   // dollar amount for this spot
    sortOrder    Int     @default(0)

    leagueDues   LeagueDues           @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)
    proposalItem PayoutProposalItem[]

    @@index([leagueDuesId])
}

// Auto-generated at season end. Commissioner reviews and approves/rejects.
model PayoutProposal {
    id           String   @id @default(cuid())
    leagueDuesId String
    // pending_commissioner | approved | rejected | polling | poll_passed | poll_failed
    status       String   @default("pending_commissioner")
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    leagueDues   LeagueDues           @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)
    items        PayoutProposalItem[]
    poll         LeaguePoll?

    @@index([leagueDuesId])
}

// Each line in the proposal: which member wins which spot.
model PayoutProposalItem {
    id           String  @id @default(cuid())
    proposalId   String
    memberId     String
    payoutSpotId String
    amount       Float
    // pending | approved | claim_sent | transfer_initiated | paid_out | failed
    status       String  @default("pending")
    stripeTransferId    String?  // Stripe transfer ID once funds sent to winner
    winnerClaimToken    String?  @unique  // secure token for winner "Claim Your Winnings" link
    claimSentAt  DateTime?  // when the claim link was last issued (for 90-day expiry cron)
    claimedAt    DateTime?
    failedReason String?  // populated when status = 'failed'

    proposal     PayoutProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
    member       DuesMember     @relation(fields: [memberId], references: [id], onDelete: Cascade)
    payoutSpot   PayoutSpot     @relation(fields: [payoutSpotId], references: [id], onDelete: Cascade)

    @@index([proposalId])
}

// Created when commissioner rejects a proposal. 75%+ yes = proposal stands.
model LeaguePoll {
    id          String    @id @default(cuid())
    proposalId  String    @unique
    question    String    @default("Do you approve the proposed payout?")
    expiresAt   DateTime  // commissioner sets deadline
    // open | passed | failed
    status      String    @default("open")
    createdAt   DateTime  @default(now())

    proposal    PayoutProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
    votes       PollVote[]
}

// One vote per member per poll.
model PollVote {
    id         String    @id @default(cuid())
    pollId     String
    memberId   String
    vote       Boolean   // true = yes (approve), false = no (reject)
    votedAt    DateTime  @default(now())

    poll       LeaguePoll  @relation(fields: [pollId], references: [id], onDelete: Cascade)
    member     DuesMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

    @@unique([pollId, memberId])  // one vote per member per poll
}

// ── League Documents (bylaws, rulebooks, etc.) ────────────────────────────────

model LeagueDocument {
    id           String   @id @default(cuid())
    leagueDuesId String
    label        String   // e.g. "Rulebook 2025", "League Bylaws"
    url          String   // Google Drive / Dropbox share link
    createdAt    DateTime @default(now())

    leagueDues   LeagueDues @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)

    @@index([leagueDuesId])
}

// ── League Announcements ─────────────────────────────────────────────────────

model Announcement {
    id           String   @id @default(cuid())
    leagueId     String?  // primary: FK to League.id (null on legacy rows backfilled from leagueDuesId)
    leagueDuesId String?  // legacy: kept for rows created before the schema migration
    authorId     String
    body         String   @db.Text
    mediaUrl     String?  // direct image / GIF URL (normalised from Giphy share links etc.)
    pinned       Boolean  @default(false)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    league       League?    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
    leagueDues   LeagueDues? @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)
    author       User       @relation("AuthorAnnouncements", fields: [authorId], references: [id], onDelete: Cascade)

    @@index([leagueId])
    @@index([leagueDuesId])
}

// Tracks which members owe dues in future seasons (e.g. acquired a future draft pick).
model FutureDuesObligation {
    id            String    @id @default(cuid())
    leagueDuesId  String
    memberId      String
    season        String    // "2026" | "2027" | "2028"
    amount        Float
    notes         String?   // e.g. "Acquired 2027 1st round pick from Team X"
    // pending | paid
    status              String    @default("pending")
    paidAt              DateTime?
    paymentMethod       String?   // "stripe_on_behalf" | "manual" | null
    stripePaymentIntentId String? // pi_xxx — stored for dispute reversal in webhook
    createdAt           DateTime  @default(now())
    updatedAt           DateTime  @updatedAt

    leagueDues    LeagueDues  @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)
    member        DuesMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

    @@unique([leagueDuesId, memberId, season])
    @@index([leagueDuesId])
    @@index([memberId])
}

// ── League Invite Links ───────────────────────────────────────────────────────

model LeagueInvite {
    id              String   @id @default(cuid())
    token           String   @unique @default(cuid())
    sleeperLeagueId String
    leagueName      String
    season          String
    createdById     String
    createdAt       DateTime @default(now())

    createdBy       User     @relation("LeagueInvites", fields: [createdById], references: [id], onDelete: Cascade)

    @@index([sleeperLeagueId])
}

// ── Sleeper Player Database ──────────────────────────────────────────────────

// Downloaded once per day via /api/cron/sleeper-players.
// Sleeper player IDs are used throughout league/roster/matchup data.
// Enriched daily via /api/cron/espn-rosters with injury and physical data.
model SleeperPlayer {
    playerId        String   @id   // Sleeper's player_id string
    fullName        String
    position        String
    team            String
    active          Boolean  @default(true)
    // ESPN enrichment fields (updated daily by espn-rosters cron)
    espnId          String?
    injuryStatus    String?  // Active | Questionable | Doubtful | Out | IR | PUP
    injuryBodyPart  String?
    jerseyNumber    Int?
    height          String?  // e.g. "6' 2\""
    weight          Int?     // lbs
    birthDate       String?  // birth_date from Sleeper API e.g. "1998-05-15" — canonical DOB source
    age             Int?     // pre-calculated by Sleeper (kept as fallback when birthDate is absent)
    yearsExp        Int?     // years_exp from Sleeper API — 0 = current rookie
    rookieYear      String?  // metadata.rookie_year — e.g. "2026"
    searchRank      Int?     // search_rank — ADP proxy; lower = higher value; 9999999 = unranked
    draftRound      Int?     // NFL draft round (1–7) from Sleeper draft_pick.round
    draftPick       Int?     // NFL draft pick within round from Sleeper draft_pick.pick_no
    // FiQ Draft Capital Engine v2.0 — true draft capital fields
    draftTeam       String?  // NFL team abbreviation that selected this player
    overallPick     Int?     // overall draft pick number (computed from round + pick_no)
    draftDay        Int?     // 1, 2, or 3 — NFL Draft day
    // Depth chart — updated daily by sleeper-players cron
    depthChartOrder Int?     // 1 = starter, 2 = backup, 3 = 3rd string, etc.
    depthChartPos   String?  // positional label e.g. "LWR", "RB1", "TE1"
    // NFL Combine athleticism data — used by FiQ Rookie Engine v1.5
    fortyTime       Float?   // 40-yard dash (seconds)
    verticalJump    Float?   // vertical jump (inches)
    broadJump       Float?   // broad jump (inches)
    threeCone       Float?   // 3-cone drill (seconds)
    shuttle         Float?   // short shuttle (seconds)
    // FiQ Production Engine v1.0 — derived college production metrics
    // Populated by the DraftSharks ingestion pipeline. All nullable.
    // Source: numeric totals only — no text/grades/proprietary scores stored.
    productionGamesPlayed                     Int?
    productionAgeAtDraft                      Float?
    productionBreakoutAge                     Float?
    productionEarlyDeclare                    Boolean?
    productionReceivingYardsPerTeamAttempt    Float?
    productionBestSeasonDominator             Float?
    productionCareerDominator                 Float?
    productionTargetShare                     Float?
    productionYardsPerRouteRun                Float?
    productionADot                            Float?
    productionRushingYardsPerTeamAttempt      Float?
    productionRushingDominator                Float?
    productionReceptionsPerGame               Float?
    productionYardsPerRouteRunRB              Float?
    productionExplosiveRunRate                Float?
    productionAdjustedCompletionRate          Float?
    productionBigTimeThrowRate                Float?
    productionTurnoverWorthyPlayRate          Float?
    productionYardsPerAttempt                 Float?
    productionRushingYardsPerGameQB           Float?
    updatedAt       DateTime @updatedAt

    projections     PlayerProjection[]
}

// Weekly fantasy point projections — populated by /api/cron/sleeper-projections.
model PlayerProjection {
    id        String   @id @default(cuid())
    playerId  String
    season    String
    week      Int
    pointsPpr Float
    pointsStd Float
    pointsHalfPpr Float
    updatedAt DateTime @updatedAt @default(now())

    player    SleeperPlayer @relation(fields: [playerId], references: [playerId], onDelete: Cascade)

    @@unique([playerId, season, week])
    @@index([season, week])
}

model FantasyCalcValue {
    id           String   @id @default(cuid())
    fcId         Int      @unique
    playerName   String
    nameLower    String   @unique
    position     String
    team         String?
    age          Float?
    dynastyValue   Int      // KTC 1QB dynasty (0–9999)
    dynastyValueSf Int      @default(0)  // KTC superflex dynasty
    redraftValue   Int      // KTC 1QB redraft (0–9999)
    redraftValueSf Int      @default(0)  // KTC superflex redraft
    trend30Day     Int?
    updatedAt    DateTime @updatedAt @default(now())

    @@index([nameLower])
}

// Weekly snapshot of power rankings per league, written by the power-rankings cron.
// Powers the historical trend view on the Rankings page.
model PowerRankingSnapshot {
    id        String   @id @default(cuid())
    leagueId  String
    week      Int
    data      Json     // array of teams with powerScore, record, PF, PA, dtv
    createdAt DateTime @default(now())

    @@unique([leagueId, week])
}

// Daily snapshot of KTC values + Sleeper metadata, taken before each fantasycalc-sync run.
// Powers the /api/players/delta endpoint (what changed since yesterday).
// Retention: 7 days (older rows deleted by the cron).
model FantasyCalcSnapshot {
    id             String   @id @default(cuid())
    nameLower      String
    position       String
    dynastyValue   Int
    dynastyValueSf Int
    redraftValue   Int
    redraftValueSf Int
    team           String?       // Sleeper team at snapshot time
    injuryStatus   String?       // Sleeper injury status at snapshot time
    takenAt        DateTime @default(now())

    @@index([nameLower])
    @@index([takenAt])
}

// ── League Payouts ────────────────────────────────────────────────────────────
// Records the payout amounts the commissioner commits to per rank.

model LeaguePayout {
    id        String    @id @default(cuid())
    leagueId  String
    rank      Int       // 1 = 1st place, 2 = 2nd, 3 = 3rd, etc.
    amount    Float
    paidAt    DateTime?
    paidBy    String    // commissioner userId
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    league    League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)

    @@unique([leagueId, rank])
    @@index([leagueId])
}

// Records the winning teams per rank (team selected from Sleeper rosters).

model LeaguePayoutWinner {
    id       String @id @default(cuid())
    leagueId String
    rank     Int
    teamId   String  // Sleeper roster_id as string
    teamName String

    league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

    @@unique([leagueId, rank])
    @@index([leagueId])
}

// ── Notifications ────────────────────────────────────────────────────────────

model Notification {
    id           String    @id @default(cuid())
    userId       String
    type         String    // notification type key (see NotificationType)
    title        String
    body         String    @db.Text
    data         Json?     // arbitrary payload (leagueId, amount, duesId, etc.)
    read         Boolean   @default(false)
    readAt       DateTime?
    emailSent    Boolean   @default(false)
    emailSentAt  DateTime?
    createdAt    DateTime  @default(now())
    expiresAt    DateTime?

    user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, read])
    @@index([userId, createdAt])
    @@index([type, userId, createdAt])
}

model NotificationPreference {
    id        String   @id @default(cuid())
    userId    String
    type      String   // notification type key, or "*" for global opt-out
    email     Boolean  @default(true)
    inApp     Boolean  @default(true)
    updatedAt DateTime @updatedAt

    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, type])
    @@index([userId])
}

// ── Stripe webhook deduplication ────────────────────────────────────────────
// Keyed on Stripe event ID. Processed before each webhook handler runs to
// prevent double-processing replays or retries.

model ProcessedStripeEvent {
    id          String   @id                         // Stripe event ID (evt_...)
    processedAt DateTime @default(now())
}

// Immutable log of every manual payment action taken by a commissioner.
// Written on: mark-paid, remove-payment, manual cash collection.
model PaymentAuditLog {
    id            String   @id @default(cuid())
    leagueDuesId  String
    memberId      String?                             // null for cash collection entries
    actorId       String                              // commissioner user ID
    action        String                              // "mark_paid" | "remove_payment" | "cash_collected"
    amount        Float
    note          String?                             // optional commissioner note
    createdAt     DateTime @default(now())

    leagueDues    LeagueDues  @relation(fields: [leagueDuesId], references: [id], onDelete: Cascade)
    actor         User        @relation("AuditLogActor", fields: [actorId], references: [id])
}

model PasswordResetToken {
    id        String    @id @default(cuid())
    userId    String
    token     String    @unique
    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime  @default(now())

    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model EmailVerificationToken {
    id        String   @id @default(cuid())
    userId    String
    token     String   @unique
    expiresAt DateTime
    createdAt DateTime @default(now())

    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

// ── LeagueFinder ─────────────────────────────────────────────────────────────

model LFCommissioner {
    id              String   @id @default(cuid())
    displayName     String
    platformHandles Json     // { sleeper?: "...", espn?: "...", yahoo?: "..." }
    avgRating       Float    @default(0)
    reviewsCount    Int      @default(0)
    flagsCount      Int      @default(0)
    ownerId         String?  @unique  // User who claimed this profile
    claimToken      String?  @unique  // Reserved for future email verification
    claimed         Boolean  @default(false)
    createdAt       DateTime @default(now())

    leagues         LFLeague[]
    reviews         LFReview[]
    owner           User?           @relation("CommissionerOwner", fields: [ownerId], references: [id])
    replyRecords    LFReviewReply[]

    @@index([avgRating])
}

model LFLeague {
    id              String   @id @default(cuid())
    name            String
    platform        String   // Sleeper | ESPN | Yahoo | MFL | Fleaflicker
    format          String   // Dynasty | Redraft | Best Ball
    scoring         String   // PPR | Half PPR | Standard | TE Premium
    size            Int
    buyIn           Int?
    payoutStructure Json?
    completedSeasons     Int     @default(0)   // each season = +20 to stabilityScore
    activityScore        Int     @default(0)   // 20/40/60/80/100 ← activityLevel 1-5
    stabilityScore       Int     @default(0)   // = min(100, completedSeasons * 20)
    verifiedReviewsCount Int     @default(0)
    rankingScore         Int     @default(0)   // composite for search ordering
    requiresMinPrs       Int?     // minimum prsScore a player must have to join; null = open to all
    commissionerId       String
    createdAt            DateTime @default(now())

    historyImport        PrsHistoryImport?

    commissioner    LFCommissioner  @relation(fields: [commissionerId], references: [id])
    reviews         LFReview[]
    joinRequests    LFJoinRequest[]
    seasons         LFLeagueSeason[]

    @@index([commissionerId])
    @@index([format])
    @@index([platform])
    @@index([rankingScore])
}

model LFReview {
    id              String   @id @default(cuid())
    leagueId        String
    commissionerId  String
    reviewerId      String
    ratingOverall   Int      // 1-5
    ratingFairness  Int      // 1-5
    ratingComm      Int      // 1-5
    ratingStability Int      // 1-5
    text            String?
    seasonYear      Int
    verified        Boolean  @default(false)
    disputed        Boolean  @default(false)
    helpfulCount    Int      @default(0)
    notHelpfulCount Int      @default(0)
    createdAt       DateTime @default(now())

    league          LFLeague       @relation(fields: [leagueId], references: [id])
    commissioner    LFCommissioner @relation(fields: [commissionerId], references: [id])
    reviewer        User           @relation("ReviewerReviews", fields: [reviewerId], references: [id])
    votes           LFReviewVote[]
    reply           LFReviewReply?

    @@unique([leagueId, reviewerId, seasonYear])
    @@index([leagueId])
    @@index([commissionerId])
    @@index([reviewerId])
}

model LFReviewVote {
    id        String   @id @default(cuid())
    reviewId  String
    voterId   String
    helpful   Boolean
    createdAt DateTime @default(now())

    review    LFReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
    voter     User     @relation("ReviewVotes", fields: [voterId], references: [id], onDelete: Cascade)

    @@unique([reviewId, voterId])
    @@index([reviewId])
}

model LFReviewReply {
    id             String   @id @default(cuid())
    reviewId       String   @unique
    commissionerId String
    ownerId        String
    text           String
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    review         LFReview       @relation(fields: [reviewId], references: [id], onDelete: Cascade)
    commissioner   LFCommissioner @relation(fields: [commissionerId], references: [id])
    owner          User           @relation("ReviewReplies", fields: [ownerId], references: [id])
}

// ── Player Reliability Score (PRS) ───────────────────────────────────────────

enum PrsEventType {
    verified_season
    season_abandoned
    retention_stayed
    retention_left
    retention_removed
    lineup_set
    lineup_missed
    trade_response
    trade_ignored
    waiver_active
    commish_approval
    commish_endorsement
    commish_flag
    commish_ban
    veto_abuse
    collusion_flag
    tanking_flag
    toxicity_report
    rule_violation
}

// Raw behavioral events — one row per event.
model PrsEvent {
    id          String       @id @default(cuid())
    userId      String
    eventType   PrsEventType
    eventValue  Int?
    eventDate   DateTime     @default(now())
    // Deduplication key for cron-ingested events.
    // Format: "txn:{transactionId}[:{sleeperUserId}]" | "lineup:{leagueId}:{season}:week{N}:{rosterId}" | "season:{leagueId}:{season}"
    // NULL for manually-submitted events (history-import, /api/prs/events).
    // A partial unique index (WHERE sourceRef IS NOT NULL) enforces uniqueness — see migration SQL.
    sourceRef   String?

    user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([userId, eventType])
    @@index([eventDate])
    @@index([sourceRef])
}

// Computed PRS — upserted nightly and on immediate-trigger events.
model PrsScore {
    id                String   @id @default(cuid())
    userId            String   @unique
    seasonScore       Int      @default(0)
    retentionScore    Int      @default(0)
    engagementScore   Int      @default(0)
    commissionerTrust Int      @default(0)
    behaviorScore     Int      @default(0)
    prs               Int      @default(0)
    updatedAt         DateTime @updatedAt

    user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([prs])
}

// Computed DSS — upserted nightly by dss-calculate cron.
model DssScore {
    id               String   @id @default(cuid())
    userId           String   @unique
    // V1 component scores (0–100 each)
    winRateScore     Int      @default(0)   // weighted avg win rate across dynasty leagues
    pfScore          Int      @default(0)   // weighted avg PF percentile rank within league
    playoffScore     Int      @default(0)   // % of seasons finishing in playoff position
    leagueStrScore   Int      @default(0)   // opponent quality (higher = tougher competition)
    // Metadata
    dynastyLeagues   Int      @default(0)   // number of dynasty leagues used for computation
    totalGames       Int      @default(0)   // total regular-season games across leagues
    dss              Int      @default(0)   // final score (0-100)
    computedAt       DateTime @default(now())
    updatedAt        DateTime @updatedAt

    user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([dss])
}

enum LFJoinStatus {
    PENDING
    ACCEPTED
    REJECTED
    PINNED
}

model LFJoinRequest {
    id           String       @id @default(cuid())
    leagueId     String
    userId       String
    status       LFJoinStatus @default(PENDING)
    introMessage String?
    createdAt    DateTime     @default(now())
    updatedAt    DateTime     @updatedAt

    league       LFLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
    user         User     @relation("LeagueJoinRequests", fields: [userId], references: [id], onDelete: Cascade)

    @@unique([leagueId, userId])
    @@index([leagueId])
    @@index([userId])
}

model LFLeagueSeason {
    id           String    @id @default(cuid())
    leagueId     String
    year         Int
    champion     String?
    payoutSent   Boolean   @default(false)
    payoutDate   DateTime?
    notes        String?
    createdAt    DateTime  @default(now())

    league       LFLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)

    @@unique([leagueId, year])
    @@index([leagueId])
}

// ── Commissioner History Import ───────────────────────────────────────────────
// Commissioners can import prior-season history for their league members once.
// The @unique on leagueId acts as the write-once lock.

model PrsHistoryImport {
    id            String   @id @default(cuid())
    leagueId      String   @unique  // one import per league — enforces the lock
    submittedById String             // commissioner's userId (audit: who submitted it)
    memberCount   Int                // how many members were processed
    submittedAt   DateTime @default(now())

    league        LFLeague              @relation(fields: [leagueId], references: [id], onDelete: Cascade)
    submittedBy   User                  @relation("PrsHistorySubmitter", fields: [submittedById], references: [id], onDelete: Cascade)
    entries       PrsHistoryImportEntry[]

    @@index([submittedById])
}

// One audit row per member processed in a history import.
model PrsHistoryImportEntry {
    id               String  @id @default(cuid())
    importId         String
    userId           String  // the member whose history was imported
    completedSeasons Int     // number of verified_season events created
    returned         Boolean // whether retention_stayed was created
    approved         Boolean // whether commish_approval was created

    import           PrsHistoryImport @relation(fields: [importId], references: [id], onDelete: Cascade)

    @@index([importId])
    @@index([userId])
}

// ── Weekly DFS Challenge ──────────────────────────────────────────────────────

enum DFSContestStatus {
    OPEN
    LOCKED
    FINAL
}

// One contest per external league per week. Shared across all members of that league.
model DFSContest {
    id               String           @id @default(cuid())
    platform         String           // "sleeper" | "espn"
    externalLeagueId String           // Sleeper/ESPN league ID (shared key)
    sourceLeagueId   String           // League.id used for roster/scoring settings
    week             Int
    season           Int
    status           DFSContestStatus @default(OPEN)
    createdAt        DateTime         @default(now())
    updatedAt        DateTime         @updatedAt

    sourceLeague     League      @relation("DFSSourceLeague", fields: [sourceLeagueId], references: [id], onDelete: Cascade)
    lineups          DFSLineup[]

    @@unique([platform, externalLeagueId, season, week])
    @@index([externalLeagueId])
    @@index([status])
}

// ── Dynasty Rookie Rankings ───────────────────────────────────────────────────
// Standalone table — no relation to DTV, trade engine, or veteran scoring.
// Powered exclusively by the FiQ Rookie Rankings engine.
model RookieRankingsPlayer {
    id          String   @id @default(cuid())
    season      String   // e.g. "2026"
    playerName  String
    school      String
    position    String   // QB | RB | WR | TE | K
    nflGrade    Float    // NFL scout grade (0–10 scale)
    fiqGrade    Float    // FiQ scouting grade (0–100)
    eliteScore  Float    // FiQ EliteScore (0–100)
    marketScore Float    // FiQ MarketScore (0–100)
    overallPick Int      // NFL Draft overall pick number
    draftCap    Float    // FiQ DraftCap score (0–100)
    baseFiQScore     Float    @default(0)  // original scouting-only FiQ score (0–100); set on seed, never overwritten
    opportunityScore Float    @default(0)  // Sleeper-derived opportunity score (0–100); updated nightly by rookie-opportunity-sync
    manualDepthOrder Int?                  // manual depth chart override (1=starter, 2=backup, 3=3rd string); used when Sleeper has no data
    height           String?              // combine/pro day height (e.g. "6'4 1/8\""); shown when Sleeper has no data
    weight           Int?                 // combine/pro day weight in lbs; shown when Sleeper has no data
    fortyTime        Float?               // combine 40-yard dash time (e.g. 4.46); for display only
    fiqScore         Float    // adjusted FiQ Score = (baseFiQScore × 0.75) + (opportunityScore × 0.25)
    fiqTier          String   // derived from adjusted fiqScore: "Tier 1"–"Tier 5"
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@unique([season, playerName])
    @@index([season, position])
    @@map("rookie_rankings_players")
}

// One lineup per user per contest.
model DFSLineup {
    id          String   @id @default(cuid())
    contestId   String
    userId      String
    // [{ slot: "QB", playerId: "123" }, { slot: "RB", playerId: "456" }, ...]
    entriesJson Json
    totalPoints Float    @default(0)
    locked      Boolean  @default(false)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    contest     DFSContest @relation(fields: [contestId], references: [id], onDelete: Cascade)
    user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([contestId, userId])
    @@index([contestId])
    @@index([userId])
}
