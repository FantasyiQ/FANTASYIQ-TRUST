{
  "name": "fantasyiq-trust",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/kill-orphan-next.mjs && next dev",
    "build": "prisma generate && prisma db push --accept-data-loss && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "dob:check": "npx tsx scripts/dobSyncValidator.ts",
    "deploy": "vercel --prod --yes",
    "test": "tsx --test src/lib/auction/computeAuctionValues.test.ts src/lib/rankings/rankingsUtils.test.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/pg": "^8.20.0",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "pusher": "^5.3.3",
    "pusher-js": "^8.5.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "resend": "^6.12.2",
    "stripe": "^22.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "vercel": "^53.1.0"
  }
}
